{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VRM Camera",
  "version": "1.0.1",
  "identifier": "dev.vrm-camera.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm vite --mode tauri",
    "beforeBuildCommand": "pnpm vite build --mode tauri"
  },
  "app": {
    "windows": [
      {
        "title": "VRM Camera",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "13.0",
      "entitlements": "Entitlements.plist"
    }
  }
}
